# =============================================================================
# Semiconductor Ops Platform - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in values for your deployment target.
# All variables are optional; the platform runs with sensible defaults.

# ---------------------------------------------------------------------------
# General
# ---------------------------------------------------------------------------
NODE_ENV=development
PORT=8000
LOG_LEVEL=info
# JSON or text log format (json | text)
LOG_FORMAT=text

# ---------------------------------------------------------------------------
# Persistence backend (sqlite | jsonl)
# ---------------------------------------------------------------------------
# Set to "sqlite" to use SQLAlchemy/SQLite persistence, or "jsonl" for legacy
# flat-file JSONL storage. Default: sqlite
PERSISTENCE_BACKEND=sqlite
# SQLite database path (only used when PERSISTENCE_BACKEND=sqlite)
DATABASE_URL=sqlite:///./data/semiconductor_ops.db

# ---------------------------------------------------------------------------
# Fab Ops domain
# ---------------------------------------------------------------------------
FAB_OPS_OPERATOR_TOKEN=
FAB_OPS_OPERATOR_ALLOWED_ROLES=shift-lead,release-supervisor
FAB_OPS_RUNTIME_STORE_PATH=
FAB_OPS_HANDOFF_SIGNING_KEY=
FAB_OPS_HANDOFF_SIGNING_KEY_ID=fab-ops-demo-v1

# ---------------------------------------------------------------------------
# Scanner domain
# ---------------------------------------------------------------------------
SCANNER_OPERATOR_TOKEN=
SCANNER_OPERATOR_ALLOWED_ROLES=field-lead,qualification-reviewer
SCANNER_RUNTIME_STORE_PATH=
SCANNER_RESPONSE_SIGNING_KEY=
SCANNER_RESPONSE_SIGNING_KEY_ID=scanner-demo-v1

# ---------------------------------------------------------------------------
# AWS integration (env-var gated: set AWS_ACCESS_KEY_ID to enable)
# ---------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-west-2
AWS_S3_BUCKET=semiconductor-ops-exports
AWS_SQS_QUEUE_URL=
AWS_DYNAMODB_TABLE=

# ---------------------------------------------------------------------------
# GCP / Cloud Run (used by Terraform and container deployments)
# ---------------------------------------------------------------------------
GCP_PROJECT_ID=
GCP_REGION=us-central1
GCP_CLOUD_RUN_SERVICE=semiconductor-ops-platform
GCP_CLOUD_RUN_MEMORY=512Mi
GCP_CLOUD_RUN_CPU=1

# ---------------------------------------------------------------------------
# Monitoring
# ---------------------------------------------------------------------------
ENABLE_METRICS=true
METRICS_PATH=/metrics
